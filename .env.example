# Copy this file to `.env`.
#
# Required in production:
#   DATABASE_URL   postgresql://user:pass@host:port/dbname   (login + user data)
#   JWT_SECRET     a long random string                      (session signing)
#
# Optional:
#   AUTH_FILE      path to a global ytmusicapi browser-auth file (improves
#                  public search results). Defaults to browser.json; absent is
#                  fine — the app runs in plain guest mode. There is no
#                  per-user YouTube account linking.
AUTH_FILE=browser.json
